<!doctype html>
<html lang="fr">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    

    <title>{% block title %}Re-Tailor{% endblock %}</title>
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    
    <style>
        body { background-color: #000000; color: white; }
        .hero-section { height: 100vh; background: linear-gradient(rgba(0, 0, 0, 0.15), rgba(0, 0, 0, 0.15)), url('images/hero.png') no-repeat center top; background-size: cover; margin-top: -70px; }
        .hero-box { padding: 3rem 6rem !important; }
        .hero-section h1 { letter-spacing: 4px; font-family: serif; }
        .bg-black { background-color: #000000 !important; }
        .border-1 { border-width: 1px !important; }
        .img-collection { width: 100%; height: 350px; object-fit: cover; display: block; }
        .form-control::placeholder { color: #ffffff !important; opacity: 0.8; }
        @media (max-width: 768px) { .hero-section { height: 70vh; margin-top: 0; } }
        .img-service { width: 100%; height: 250px; object-fit: cover; display: block; }
    </style>
</head>
<body>

    {% include '_navbar.html.twig' %}

    <main>
        {% block body %}
        {% endblock %}
    </main>

    {% include '_footer.html.twig' %}

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>